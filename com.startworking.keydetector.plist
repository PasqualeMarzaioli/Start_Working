<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  com.startworking.keydetector.plist — macOS LaunchAgent for StartWorking

  This file tells macOS to start the key detector automatically at every login.

  INSTALLATION:
    1. Run setup.sh to configure paths.
    2. Copy this file to ~/Library/LaunchAgents/:
         cp com.startworking.keydetector.plist ~/Library/LaunchAgents/
    3. Register the agent with launchd:
         launchctl load ~/Library/LaunchAgents/com.startworking.keydetector.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.startworking.keydetector</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/osascript</string>
        <string>-e</string>
        <string>delay 15
tell application "Terminal"
    do script "nohup /Users/pasquale_marzaioli/Desktop/Coding/start_working/venv/bin/python3 /Users/pasquale_marzaioli/Desktop/Coding/start_working/key_detector.py > /Users/pasquale_marzaioli/Desktop/Coding/start_working/key_detector.log 2&gt;&amp;1 &amp;; sleep 2; exit"
    activate
end tell
delay 4
tell application "Terminal" to close front window</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/pasquale_marzaioli/Desktop/Coding/start_working/launchagent.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/pasquale_marzaioli/Desktop/Coding/start_working/launchagent.log</string>
</dict>
</plist>
