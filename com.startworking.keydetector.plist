<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  com.startworking.keydetector.plist — macOS LaunchAgent for StartWorking

  This file tells macOS to start the key detector automatically at every login.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.startworking.keydetector</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/osascript</string>
        <string>-e</string>
        <string>delay 15
tell application "Terminal"
    set newWindow to do script "nohup /Users/pasquale_marzaioli/Desktop/Coding/start_working/venv/bin/python3 /Users/pasquale_marzaioli/Desktop/Coding/start_working/key_detector.py > /Users/pasquale_marzaioli/Library/Logs/StartWorking/key_detector.log 2&gt;&amp;1 &amp;; sleep 2; exit"
    set visible of first window to false
end tell</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/pasquale_marzaioli/Library/Logs/StartWorking/launchagent.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/pasquale_marzaioli/Library/Logs/StartWorking/launchagent.log</string>
</dict>
</plist>
